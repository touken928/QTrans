{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    
    "minor": 21,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake"
      }
    },
    {
      "name": "default",
      "hidden": true,
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    },
    {
      "name": "release",
      "hidden": true,
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "arm64-osx-release",
      "displayName": "macOS arm64 (Release)",
      "description": "Release build for macOS arm64.",
      "inherits": "release",
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "arm64-osx-release"
      }
    },
    {
      "name": "x64-mingw-release",
      "displayName": "MinGW x64 (Release)",
      "description": "Release build for Windows x64 using MinGW.",
      "inherits": "release",
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "x64-mingw-static"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "arm64-osx-release",
      "displayName": "macOS arm64 (Release)",
      "configurePreset": "arm64-osx-release"
    },
    {
      "name": "x64-mingw-release",
      "displayName": "MinGW x64 (Release)",
      "configurePreset": "x64-mingw-release"
    },
    {
      "name": "debug",
      "displayName": "Local development (Debug)",
      "configurePreset": "default"
    }
  ]
}
